# ============================================
# PREENCHA ANTES DE SUBIR
# ============================================

# Senha do banco local (pode inventar uma forte)
DB_PASSWORD=TROCAR_SENHA_FORTE_AQUI

# NextAuth (gere com: openssl rand -base64 32)
NEXTAUTH_SECRET=TROCAR_GERAR_COM_OPENSSL
NEXTAUTH_URL=https://SEU_DOMINIO_AQUI

# Chatwoot API
CHATWOOT_BASE_URL=https://SEU_CHATWOOT_AQUI
CHATWOOT_API_TOKEN=SEU_TOKEN_AQUI
CHATWOOT_ACCOUNT_ID=1
CHATWOOT_INBOX_ID=1

# Chatwoot PostgreSQL (banco do Chatwoot para leitura)
# Se o Chatwoot roda em Docker, use o nome do container ou IP interno
CHATWOOT_DB_HOST=TROCAR_HOST_DO_BANCO_CHATWOOT
CHATWOOT_DB_PORT=5432
CHATWOOT_DB_NAME=chatwoot_production
CHATWOOT_DB_USER=postgres
CHATWOOT_DB_PASSWORD=TROCAR_SENHA_BANCO_CHATWOOT

# Claude API (Anthropic)
ANTHROPIC_API_KEY=sk-ant-TROCAR

# Google Drive
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_KEY=
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# Jobs
POLL_INTERVAL_MINUTES=2
